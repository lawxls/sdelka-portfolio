# Base URL all HTTP adapters join their paths onto. Defaults to `/api/v1`
# in code; set this when the SPA is served from a different origin than the
# Django backend (e.g. `https://api.example.com/api/v1`).
VITE_API_BASE_URL=/api/v1

# Per-entity adapter mode (`memory` | `http`). Default `memory` so local dev
# works without a running backend. Flip an entity to `http` to route its
# client at the live API.
# VITE_DATA_COMPANIES=memory
# VITE_DATA_ITEMS=memory
# VITE_DATA_SUPPLIERS=memory
# VITE_DATA_TASKS=memory
# VITE_DATA_TENDERS=memory
# VITE_DATA_FOLDERS=memory
# VITE_DATA_NOTIFICATIONS=memory
# VITE_DATA_EMAILS=memory
# VITE_DATA_PROFILE=memory
# VITE_DATA_WORKSPACE_EMPLOYEES=memory
# VITE_DATA_COMPANY_INFO=memory
